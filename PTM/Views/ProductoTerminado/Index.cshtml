                                <tr class="text-center">
                                    <td>Juan Pérez García</td>
                                    <td>Operador</td>
                                    <td>contacto@ptmmexico.com</td>
                                </tr>
                                <tr class="text-center">
                                    <td>Juan Pérez García</td>
                                    <td>Operador</td>
                                    <td>contacto@ptmmexico.com</td>
                                </tr>
