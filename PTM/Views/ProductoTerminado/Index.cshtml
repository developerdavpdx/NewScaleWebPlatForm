</div>

<div class="modal fade" style="max-width: 100%; display:none; overflow: auto" id="detalleLineModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog">
        <div class="modal-content modaldetailsCss">
            <div class="modal-header">
                @*<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>*@
                <h4 class="modal-title" id="myModalLabel">Detalle Línea <b id="lineaModal" style="font-size: 16px; font-weight: normal;"></b></h4>
            </div>
            <div class="modal-body">

                <div class="container titleHeader">
                    <h2 style="padding-top: 7px;">PVC: LÍNEA <b id="lineaTitleModal"></b></h2>
                </div>
                <br />
                
                <table id="tableDetalladaLinea" class="table">
                    <div class="Totales" style="display: flex; flex-direction: column; width: 80%;">
                        <div style="width: 100%;  display: flex; justify-content: space-between;">
                            <labe style="color: #075da5; font-weight: bold; font-size:13px;">P. Neto Total: <span style="color: black; font-size: 13px;" id="sumTotalLinea">--</span></labe>
                            <labe style="color: #075da5; font-weight: bold; font-size: 13px;">P. Unit. Estandár: <span style="color: black; font-size: 13px;" id="sumEstandarLinea">--</span></labe>
                            <labe style="color: #075da5; font-weight: bold; font-size: 13px;">% Sobrepeso: <span style="color: black; font-size: 13px;" id="sumSobrePesoLinea"></span></labe>
                            <labe style="color: #075da5; font-weight: bold; font-size: 13px;">% Eficiencia: <span style="color: black; font-size: 13px;" id="sumEficienciaLinea">--</span></labe>
                            @*<labe style="color: #075da5; font-weight: bold; font-size: 13px;">KG ScrapPT: <span style="color: black; font-size: 13px;" id="sumScrapPtKgLinea">--</span></labe>*@
                            @*<labe style="color: #075da5; font-weight: bold; font-size: 13px;">% Scrap PT: <span style="color: black; font-size: 13px;" id="sumScrapPtLinea">--</span></labe>*@
                        </div>
                        @* Boton descargar excel details *@
                        <div>
                            <i onclick="generarexcelDetallesLinea();" class="fa fa-table m-1 fa-2x t-b" aria-hidden="true" style="color: #016E38"></i>
                        </div>
                    </div>
                    @* TABLA DETALLES *@
                    <thead>
                        <tr id="tableHeadInfo">
                            <th>Fecha</th>
                            <th>Código</th>
                            <th>Atados</th>
                            <th>#Tubos</th>
                            <th>P. Neto Total</th>
                            <th>P. Unitario Estándar</th>
                            <th>P. Unit. Real</th>
                            <th>% Sobrepeso</th>
                            <th>% Eficiencia</th>
                        </tr>
                    </thead>
                    <tbody id="tableBodyDetalle" class="text-center">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" id="cerrarModalDetails" class="btn btn-danger" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

