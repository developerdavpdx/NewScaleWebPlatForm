
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <link href="~/Styles/ProductoTerminado.css" rel="stylesheet" />
</head>

<!--Filtros PT-->
<div class="containerFilters p-4">
    <div class="row">
        <div class="col-6">
            <label>Fecha</label>
            <div class="row align-items-center" style="padding-right: 33px;">
                <div class="col-5">
                    <input class="form-control" type="date" id="desdeFecha" />
                </div>
                <div class="col-auto">
                    <label>Al</label>
                </div>
                <div class="col-5" style="left: -9px;">
                    <input class="form-control" type="date" id="aFecha" />
                </div>
            </div>
        </div>

        <div class="col-2">
            <label>Turno</label>
            <select id="turnoPT" class="form-control">
            </select>
        </div>
        <div class="col-1">
            <label>Código</label>
            <input class="form-control" id="codigo" />
        </div>
        <div class="col-1">
            <label>Línea</label>
            <input class="form-control" id="linea" />
        </div>
        <div class="col-2 iconSearch" id="search">
            <i class="fa fa-search" aria-hidden="true" style="font-size: 30px; cursor: pointer" onclick="filtradoHistorialPesadas()"></i>
        </div>
    </div>
</div>
<br />

<div class="container table-responsive">
    <div class="mt-3 mb-3 d-flex justify-content-between">
        <div class="Totales" style="display: flex; flex-direction: column; width: 80%;">

            <div style="width: 100%;  display: flex; justify-content: space-between;">
                <labe style="color:#075da5; font-weight: bold;">P. Neto Total: <span style="color: black" id="sumTotal">--</span></labe>
                <labe style="color:#075da5; font-weight: bold;">P. Unit. Estandár: <span style="color: black" id="sumEstandar">--</span></labe>
                <labe style="color:#075da5; font-weight: bold;">% Sobrepeso: <span style="color: black" id="sumSobrePeso"></span></labe>
                @*<labe style="color:#075da5; font-weight: bold;">% Scrap: <span style="color: black" id="sumScrap">--</span></labe>*@
                <labe style="color:#075da5; font-weight: bold;">% Eficiencia: <span style="color: black" id="sumEficiencia">--</span></labe>
                <labe style="color:#075da5; font-weight: bold;">KG ScrapPT: <span style="color: black" id="sumScrapPtKg">--</span></labe>
                <labe style="color:#075da5; font-weight: bold;">% Scrap PT: <span style="color: black" id="sumScrapPt">--</span></labe>
            </div>
        </div>
        <div class="card-i p-3" style="width:auto; height: 60px;">
            <i onclick="generarexcel();" class="fa fa-table m-1 fa-2x t-b" aria-hidden="true" style="color: #016E38"></i>
            <i onclick="generarpdf();" class="fa-solid fa-file-pdf m-1 fa-2x t-b" style="color: #ad0b00"></i>
            <i class="fa fa-envelope m-1 fa-2x t-b" aria-hidden="true" data-toggle="modal" data-target="#CorreoModal" style="color: #51B5E1; cursor: pointer"></i>
            @*<i class="fa fa-print m-1 fa-2x t-b" aria-hidden="true" style="color: #51B5E1"></i>*@
        </div>
    </div>
    <div class="container titleHeader">
        <h2 style="padding-top: 7px;"> PRODUCTO TERMINADO PVC</h2>
    </div>
    <br />
    <!--Tabla de producto terminado-->
    <table id="finishProdTable" style="background-color: white">
        <thead>
            <tr class="info">
                <th>Detalles</th>
                <th>Línea</th>
                <th>Código</th>
                <th># Atados/Tarima</th>
                <th># Tubos</th>
                <th>P. Neto Total</th>
                <th>P. Unit. Estándar</th>
                <th>P. Unit. Real</th>
                <th>% Sobrepeso</th>
                <th>% Eficiencia</th>
                <th>KG Scrap Pt</th>
                <th class="scrap-head">% ScrapPT</th>
            </tr>
        </thead>
        <tbody id="tableProductoPVC" class="text-center">
        </tbody>
    </table>

    <!--Tabla de scrap title-->
    <div class="container titleHeader">
        <h2 style="padding-top: 7px;"> SCRAP ESCANEADO</h2>
    </div>
    <!--Filtros Scrap-->
    <div class="containerFilters p-4">
        <div class="row">
            <div class="col-6">
                <label>Fecha </label>
                <div class="row align-items-center" style="padding-right: 33px;">
                    <div class="col-5">
                        <input class="form-control" type="date" id="desdeFechaScrap" />
                    </div>
                    <div class="col-auto">
                        <label>Al</label>
                    </div>
                    <div class="col-5" style="left: -9px;">
                        <input class="form-control" type="date" id="aFechaScrap" />
                    </div>
                </div>
            </div>
            <div class="col-2">
                @* Esto para la tabla de scrap *@
                <label>Corte</label>
                <select id="corte" class="form-control">
                    <option value=null selected>Seleccione...</option>
                    <option value="1">Corte 1 (De 5:45 am a 17:44 pm)</option>
                    <option value="2">Corte 2 (De 17:45pm  a 5:44 am)</option>
                </select>
            </div>
            <div class="col-1">
                <label>Código</label>
                <input class="form-control" id="codigoScrap" />
            </div>
            <div class="col-1">
                <label>Línea</label>
                <input class="form-control" id="lineaScrap" />
            </div>
            <div class="col-2 iconSearch">
                <i id="btn21" class="fa fa-search" aria-hidden="true" style="font-size: 30px; cursor: pointer"></i>
            </div>
            <div class="card-i p-3" style="width:auto;">
                <i onclick="generarexcelScrap();" class="fa fa-table m-1 fa-2x t-b" aria-hidden="true" style="color: #016E38"></i>
                <i onclick="generarpdfScrap();" class="fa-solid fa-file-pdf m-1 fa-2x t-b" style="color: #ad0b00"></i>
                    @*Total de scrap  *@
                <labe style="color: #075da5; font-weight: bold; font-size: 13px; padding-left:35px;">KG ScrapPT: <span style="color: black; font-size: 13px;" id="SumScrapKG">--</span></labe>
            </div>
            
        </div>
    </div>
    <br />
    <!--Tabla scrap-->
    <table id="finishScrapTable" style="background-color: white">
        <thead>
            <tr class="info">
                <th>Línea</th>
                <th>Familia</th>
                <th>Peso</th>
                <th>Comentario</th>
                <th>Fecha y hora</th>
            </tr>
        </thead>
        <tbody id="tableScrap" class="text-center">
        </tbody>
    </table>
</div>

