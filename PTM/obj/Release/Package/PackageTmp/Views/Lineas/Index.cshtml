
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <link rel="stylesheet" href="~/Styles/Lineas.css" />
</head>

<h2 class="text-center font-weight-bold mt-3">LÍNEAS</h2>

<div class="col-8 p-3">
    <div class="mt-3 card shadow-lg rounded-lg p-3 col-4">
    
        <div class="input-group mt-3" style="width:100%;">
            <div class="row w-100">
                <div class="col-3" style="text-align:end;">
                    <label class="m-1" style="font-size: small;">Línea</label>
                </div>
                <div class="col-9 input-group">
                    <input type="text" class="form-control p-3" id="li-linea" style="height:25px;">
    
                </div>
            </div>
        </div>
    
    
        <div class="input-group mt-3" style="width:100%;">
            <div class="row w-100">
                <div class="col-3" style="text-align:end;">
                    <label class="m-1" style="font-size: small;">Capacidad</label>
                </div>
                <div class="col-9 input-group">
                    <input type="text" class="form-control p-3" id="li-capacidad" style="height:25px;">
    
                </div>
            </div>
        </div>
    
    
        <div class="d-flex justify-content-end mt-3">
            <button class="btn btn-primary border-0 " style="background-color:white; color:#51b5e1; margin-right:5px;"><i class="fa fa-table m-1 fa-2x t-b" aria-hidden="true" style="color: #016E38"></i></button>
            <button class="btn btn-primary border-0 p-3" style="background-color:#51b5e1;"><i class="fa fa-plus" aria-hidden="true"></i> Agregar</button>
        </div>
    </div>
    
    <div class="col-8 p-3">
    
        <div class="card shadow-lg rounded-lg p-3">
            <table class="table table-bordered">
    
                <thead>
                    <tr class="text-center text-light" style="background:#51b5e1;">
                        <th rowspan="2">Línea</th>
                        <th rowspan="2">Código</th>
                        <th rowspan="2">Capacidad Kg/Hr</th>
                        <th rowspan="2">Usuario</th>
                        <th colspan="2" style="border: solid 5px black">
                            Última actualización
                        </th>
                    </tr>
    
                    <tr class="text-center text-light" style="background:#51b5e1;">
                        <th>Fecha</th>
                        <th>Hora</th>
                    </tr>
    
                </thead>
                <tbody>
