            <button class="btn btn-primary border-0 p-3 btn-lg" style="background-color:#51b5e1;"><i class="fa fa-ban" aria-hidden="true"></i> Cancelar</button>
            <button class="btn btn-primary border-0 p-3 btn-lg" style="background-color:#51b5e1; margin-left:20px;"><i class="fa-regular fa-floppy-disk"></i>    Guardar</button>
        </div>
