<div class="container titleHeader">
    <h2 style="padding-top: 7px;">HISTORIAL PESADAS</h2>
</div>
<br />
@* Filtros Historial pesadas *@
<div class="containerFilters p-4">
    <div class="row">
        <div class="col-4">
            <label>Fecha </label>
            <div class="row align-items-center">
                <div class="col-5">
                    <input class="form-control" type="date" id="desdeFecha" />
                </div>
                <div class="col-auto">
                    <label>Al</label>
                </div>
                <div class="col-5"  style="left:-15px;">
                    <input class="form-control" type="date" id="aFecha"/>
                </div>
            </div>
        </div>
        <div class="col-2">
            <label>Turno</label>
            <select id="turno" class="form-control">
            </select>
        </div>
        <div class="col-2">
            <label>Código</label>
            <input class="form-control" id="codigo" />
        </div>
        <div class="col-1">
            <label>Línea</label>
            <input class="form-control" id="lineaHP" />
        </div>
        <div class="col-2">
            <label>Estatus SAP</label>
            <select class="form-control" id="selectEstatus">
                <option value="0" selected>Seleccione...</option>
                <option value="1">Enviado</option>
                <option value="2">Sin Enviar</option>
                <option value="3">Error</option>
            </select>
        </div>
        <div class="col-auto iconSearch" id="search">
            <i class="fa fa-search" aria-hidden="true" style="font-size: 30px; cursor: pointer" onclick="filtradoHistorialPesadas()"></i>
        </div>
    </div>
</div>
<br />

<div class="d-flex justify-content-end">
    <div class="card-i p-3" style="width:auto; height: 58px;">
        <div class="row m-1 t-b">
            
            <div class="col-12">
                <input type="checkbox" id="checkboxSelect" onclick="checkBoxSeleccionar()" />
                <span style="font-size:15px; margin-left: 5px">Seleccionar todos</span>
                <i onclick="generarexcel();" class="fa fa-table m-1 fa-2x t-b" aria-hidden="true" style="color: #016E38; margin-left: 10px !important; "></i>
            </div>
        </div>
    </div>
</div>
<div class="container table-responsive p-4 containerHP" style="background-color:white">
    <table id="PesadasTable" class="tableHP">
        <thead>
            <tr class="info" style="text-align: center;">
                <th></th>
                <th style="width: 112.3594px !important">Fecha Pesaje</th>
                <th>Línea</th>
                <th>Código</th>
                <th>Tipo</th>
                <th>Turno</th>
                <th>Cantidad</th>
                <th>Orden Fabricación</th>
                <th>Atado</th>
                <th>P.Neto</th>
                <th>Tara</th>
                <th>Anillo</th>
                <th>Fleje</th>
                <th>Sobrepeso</th>
                <th>Estatus</th>
                <th>Estatus SAP</th>
                <th>Folio SAP</th>
                <th>Comentario SAP</th>
                <th>Comentarios</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="bodyTablePesadas" class="text-center">
        </tbody>
    </table>

</div>

<div class="mt-3 mb-3 d-flex justify-content-end">
    <div class="card-i p-3" style="width:auto;">
        <div class="row m-1 t-b">
            <div class="col-6">
                <button class="btn btn-info m-1 t-b" style="width:110px;" onclick="EnviarASap()">Enviar SAP</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="CorreoModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog">
        @*<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>*@
        <div class="modal-content">
            <div class="modal-header">

                <h4 class="modal-title" id="myModalLabel">Envío de Correo</h4>
            </div>
            <div class="modal-body">
                
                <div class="correos">
                    <label>Correos:</label>
                    <table id="tablaCorreo" class="table table-striped">
                        <thead>
                            <tr class="header-table">
                                <th id="th-pedidas">Nombre</th>
                                <th id="th-pedidas">Departamento</th>
                                <th id="th-pedidas">Correo</th>
                            </tr>
                        </thead>
                        <tbody>
                            
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-info" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-info">Enviar</button>
            </div>
        </div>
    </div>
</div>



<div class="modal fade" id="AgregaComenModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content modal-lg">
            <div class="modal-header" style="color: white; background-color: #595959; font-size: 20px; height: 40px; display: flex; align-items: center; border-top-left-radius: 4px;">
                <h4 class="modal-title" id="myModalLabel">Eliminar Registro</h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        <label style="font-size: 1.4rem !important">Ingrese el motivo a deshabilitar el registro</label>
                        <textarea class="form-control" id="textAreaComentario" style="width:94%"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal" id="cerrarModal">Cerrar</button>
                <button type="button" class="btn btn-info" id="deshabilita_historialpesadasevent" iddestino ="">Deshabilitar</button>
            </div>
        </div>
    </div>
</div>

@* Start Modal de edcion *@
<div class="modal fade" id="EdicionRegModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content modal-lg">
            <div class="modal-header" style="color: white; background-color: #595959; font-size: 20px; height: 40px; display: flex; align-items: center; border-top-left-radius: 4px;">
                <h4 class="modal-title" id="myModalLabel">Editar Registro</h4>
            </div>
            <div class="modal-body">
                <form class="formulario">
                    <p>
                        <label>Cantidad Tubos</label>
                        <input class="form-control" id="cantidad" type="number" name="cantidad" required>
                    </p>
                    <p>
                        <label>Atado</label>
                        <input class="form-control" id="atado" type="number" name="atado">
                    </p>
                    <p>
                        <label>Peso Neto</label>
                        <input class="form-control" id="pesoNeto" type="number" name="pesoNeto" required>
                    </p>
                    <p>
                        <label>Tara</label>
                        <input class="form-control" id="tara" type="number" name="tara" required>
                    </p>
                    <p>
                        <label>Anillo</label>
                        <input class="form-control" id="anillo" type="number" name="anillo" required>
                    </p>
                    <p>
                        <label>Fleje</label>
                        <input class="form-control" id="fleje" type="number" name="fleje" required>
                    </p>
                    <p>
                        <label>Línea</label>
                        <select class="form-control" id="selectLinea">
                            <option value="0" selected>Seleccione...</option>
                        </select>
                    </p>
                    <p>
                        <label>Código</label>
                        <select class="form-control" id="selectSku">
                            <option value="0" selected>Seleccione...</option>
                        </select>
                    </p>
                    <p class="full">
                        <label>Comentario</label>
                        <textarea class="form-control" id="comentario" name="comentario" required></textarea>
                    </p>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal" id="cierraModal">Cerrar</button>
                <button type="button" class="btn btn-primary copiar_registro">Copiar</button>
                <button type="button" id="btn-save" class="btn btn-info" onclick="GuardarEdicion()">Guardar</button>
            </div>
        </div>
    </div>
</div>
@* Modal End *@

<div class="modal fade" id="BitacoraModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content modal-lg">
            <div class="modal-header" style="color: white; background-color: #595959; font-size: 20px; height: 40px; display: flex; align-items: center; border-top-left-radius: 4px;">
                <h4 class="modal-title" id="myModalLabel">Bitácora Registro</h4>
            </div>
            <div class="container table-responsive p-4 containerHP">
                <table class="table table-striped" id="BitacoraHistorial">
                    <thead>
                        <tr>
                            <th>Fecha Modificación</th>
                            <th>Trabajador</th>
                            <th>Peso Total</th>
                            <th>Código</th>
                            <th>Num. Tubos</th>
                            <th>Atado</th>
                            <th>Tara</th>
                            <th>Anillo</th>
                            <th>Fleje</th>
                            <th>Línea</th>
                        </tr>
                    </thead>
                    <tbody class="text-center" id="bodyBitacoraPesadas">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal" id="cierraModal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/HistorialPesadas/HistorialPesada.js"></script>
<script src="~/Scripts/FormulasPTM.js"></script>
@*<script src="~/Scripts/EmailTXT/EmailTXT.js"></script>*@