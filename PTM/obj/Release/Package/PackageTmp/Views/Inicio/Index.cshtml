@using System.Text;

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .titleHeader {
        text-align: center;
        background-color: #075DA5;
        color: white;
        font-size: 22px;
        height: 50px;
        font-weight: bolder;
    }

    .carousel {
        position: relative;
        width: 100%;
        height: 500px;
        overflow: hidden;
    }

    .carousel-inner {
        position: absolute;
        display: flex;
        width: 300%;
        height: 100%;
        transition: transform 0.5s ease-in-out;
    }

    .carousel-item {
        flex: 1;
        width: 100%;
        height: 100%;
    }

    .highcharts-figure {
        margin: 0;
    }

    .highcharts-container {
        width: 100%;
        height: 100%;
    }

    .swiper {
        width: 100%;
        height: 650px;
    }

    .scaleIcon {
        font-size: 35px;
    }
</style>

<br />
@* Actualizar/visualizar Datos objetivos *@
@* PPVC *@
<div id="DivObjetivosPPVC" class="row d-flex justify-content-center align-items-center flex-nowrap mb-2">
    <div class="col-auto" style="width:8%;">
        <span style="font-size:1.5rem; font-weight:bold;">PPVC</span>
    </div>
    <div class="col-auto">
        <span style="font-size:1.5rem">Sobre Peso Objetivo</span>
    </div>
    <div class="col-auto">
        <input id="SobrepesoObj" class="form-control FormControlTexts" style="width: 100px;" required />
    </div>
    <div class="col-auto">
        <span style="font-size:1.5rem">Scrap Objetivo</span>
    </div>
    <div class="col-auto">
        <input id="ScrapObj" class="form-control FormControlTexts" style="width: 100px;" required />
    </div>
    <div class="col-auto">
        <button id="BtnUpdateObjPPVC" class="btn btn-info">Actualizar</button>
    </div>
</div>

@* INY *@
<div id="DivObjetivosINY" class="row d-flex justify-content-center align-items-center flex-nowrap mb-2">
    <div class="col-auto" style="width:8%;">
        <span style="font-size:1.5rem; font-weight:bold;">INY</span>
    </div>
    <div class="col-auto">
        <span style="font-size:1.5rem">Sobre Peso Objetivo</span>
    </div>
    <div class="col-auto">
        <input id="SobrepesoObjINY" class="form-control FormControlTexts" style="width: 100px;" required />
    </div>
    <div class="col-auto">
        <span style="font-size:1.5rem">Scrap Objetivo</span>
    </div>
    <div class="col-auto">
        <input id="ScrapObjINY" class="form-control FormControlTexts" style="width: 100px;" required />
    </div>
    <div class="col-auto">
        <button id="BtnUpdateObjINY" class="btn btn-info">Actualizar</button>
    </div>
</div>


<div class="container titleHeader">
    <h2 style="padding-top: 7px;"> ESTATUS DEL DÍA: TURNO <b id="labelTurno" style="font-weight: normal"></b> </h2>
</div>

<!--CONETEDOR PPVC-->
<div id="TitlePpvc" class="container">
    <h2 style="padding-top: 7px; font-weight: bold"> PPVC </h2>
</div>

@* TIUTLOS PPVC *@
<div id="DivTitulosPPVC" class="row" style="padding-top: 10px; width: 99%;">
    <!-- Volumen -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-bottom-dark shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2 text-center">
                        <i class="fa fa-balance-scale scaleIcon" aria-hidden="true"></i>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="color: #3cb2fd">
                            Volumen
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="volumenInfo">--</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Sobrepeso -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-bottom-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2 text-center">
                        <i class="fa fa-exclamation scaleIcon" aria-hidden="true"></i>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" id="SobrePeso">
                            Sobrepeso
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="infoSobrePeso">--</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Eficiencia -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-bottom-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2 text-center">
                        <i class="fa fa-check scaleIcon" aria-hidden="true"></i>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Eficiencia
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="eficicienciaInfo">--</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Scrap -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-bottom-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2 text-center">
                        <i class="fa fa-trash scaleIcon" aria-hidden="true"></i>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Scrap
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="scrapInfo">--</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* swiper PPVC*@
<div class="swiper" id="swiperPPVC">
    <!-- Additional required wrapper -->
    <div class="swiper-wrapper">
        <!-- Slides -->
        <div class="swiper-slide">
            <figure class="highcharts-figure">
                <div id="VolumenesPPVC" style=" height: 600px; margin: 15px"></div>
            </figure>
        </div>
        <div class="swiper-slide">
            <figure class="highcharts-figure">
                <div id="SobrepesoPPVC" style=" height: 600px; margin: 15px"></div>
            </figure>
        </div>
        <div class="swiper-slide">
            <figure class="highcharts-figure">
                <div id="EficienciaPPVC" style=" height: 600px; margin: 15px"></div>
            </figure>
        </div>
        <div class="swiper-slide">
            <figure class="highcharts-figure">
                <div id="ScrapPPVC" style=" height: 600px; margin: 15px"></div>
            </figure>
        </div>
    </div>


    <!-- If we need navigation buttons -->
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>

    <!-- If we need scrollbar -->
    <div class="swiper-scrollbar"></div>
</div>

