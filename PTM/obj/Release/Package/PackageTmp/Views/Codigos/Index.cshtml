
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <link rel="stylesheet" href="~/Styles/Codigos.css" />
</head>

<h2 class="text-center font-weight-bold mt-3">CÓDIGOS</h2>

<div class="row mt-3">
    <div class="col-4 p-3">
        <div class="card shadow-lg rounded-lg p-3">
            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <div class="col-4" style="text-align:end;">
                        <label class="m-1" style="font-size: small;">Código</label>
                    </div>
                    <div class="col-6 input-group">
                        <input type="text" class="form-control p-3" id="cod-codigo" style="height:25px;">
                        <span class="input-group-btn">
                            <button class="btn btn-default" style="height: 25px; display: flex; align-items: center" type="button"><></button>
                        </span>
                    </div>
                </div>
            </div>

            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <div class="col-4" style="text-align:end;">
                        <label class="m-1" style="font-size: small;">Tubo por atado</label>
                    </div>
                    <div class="col-8 input-group">
                        <input type="text" class="form-control p-3" id="cod-pesoporatado" style="height:25px;">

                    </div>
                </div>
            </div>

            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <div class="col-4" style="text-align:end;">
                        <label class="m-1" style="font-size: small;">Peso Tubo</label>
                    </div>
                    <div class="col-8 input-group">
                        <input type="text" class="form-control p-3" id="cod-pesotubo" style="height:25px;">
                    </div>
                </div>
            </div>

            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <div class="col-4" style="text-align:end;">
                        <label class="m-1" style="font-size: small;">Peso atado</label>
                    </div>
                    <div class="col-8 input-group">
                        <input type="text" class="form-control p-3" id="cod-pesoatado" style="height:25px;">
                    </div>
                </div>
            </div>

            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <div class="col-4" style="text-align:end;">
                        <label class="m-1" style="font-size: small;">Tara</label>
                    </div>
                    <div class="col-8 input-group">
                        <input type="text" class="form-control p-3" id="cod-tara" style="height:25px;">
                    </div>
                </div>
            </div>

            <div class="input-group mt-3" style="width:100%;">
                <div class="row w-100">
                    <input type="file">
                </div>
            </div>

            <div class="row mt-3 w-100">
                <div class="col-4"></div>
                <div class="col-8">

                    <div class="row">
                        <div class="col-6">
                            <input type="radio" id="cod-pt" name="cod-r" value="PT">
